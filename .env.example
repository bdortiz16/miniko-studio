# ─── Wompi (pagos, Colombia) ──────────────────────────────────────
# En tu panel de Wompi → Desarrolladores. Empieza con las de PRUEBA
# (pub_test_/prv_test_); al aprobarte, cambia a producción (pub_prod_/prv_prod_).
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxx
# Secreto de integridad (firma del checkout).
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxxxxxxxxxxx
# Secreto de eventos (verifica el webhook). Opcional en pruebas.
WOMPI_EVENTS_SECRET=test_events_xxxxxxxxxxxxxxxxx

# URL pública del sitio (sin barra final). En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase Storage (subida de fotos) ───────────────────────────
# En tu proyecto Supabase → Settings → API.
# Crea un bucket PÚBLICO llamado "pedidos" en Storage.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Clave SECRETA (solo servidor). Formato nuevo: sb_secret_...  (o la legacy service_role)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxx
SUPABASE_BUCKET=pedidos

# ─── Resend (email con código de verificación) ────────────────────
# Crea la clave en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# Remitente. Para pruebas puedes usar onboarding@resend.dev (solo envía a tu propio email).
# En producción usa un dominio verificado, p. ej. "Miniko Studio <hola@tudominio.com>"
EMAIL_FROM=Miniko Studio <onboarding@resend.dev>

# Secreto para firmar los códigos de verificación (cualquier cadena larga y aleatoria)
AUTH_SECRET=cambia-esto-por-una-cadena-larga-y-secreta

# ─── Panel de administración (/admin) ─────────────────────────────
# Contraseña para entrar al panel privado de pedidos. Si la dejas vacía, el
# panel queda SIN protección. Pon una contraseña fuerte en Vercel.
ADMIN_PASSWORD=pon-aqui-una-contraseña-fuerte

# ─── OpenAI (muestras de estilo del catálogo) ─────────────────────
# Crea la clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Replicate (vista previa del cliente con máximo parecido) ──────
# Token en https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...
