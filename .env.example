# ─── Stripe (pagos) ───────────────────────────────────────────────
# Consíguelas en https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# URL pública del sitio (sin barra final). En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Vercel Blob (subida de fotos) ────────────────────────────────
# En Vercel: pestaña Storage → Create → Blob. Copia el token de lectura/escritura.
# En local lo necesitas en .env.local; en Vercel se añade solo al crear el Blob.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxx

# ─── Resend (email con código de verificación) ────────────────────
# Crea la clave en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# Remitente. Para pruebas puedes usar onboarding@resend.dev (solo envía a tu propio email).
# En producción usa un dominio verificado, p. ej. "Miniko Studio <hola@tudominio.com>"
EMAIL_FROM=Miniko Studio <onboarding@resend.dev>

# Secreto para firmar los códigos de verificación (cualquier cadena larga y aleatoria)
AUTH_SECRET=cambia-esto-por-una-cadena-larga-y-secreta
